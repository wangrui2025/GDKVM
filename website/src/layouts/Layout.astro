---
import 'katex/dist/katex.min.css';
import { ClientRouter } from 'astro:transitions';
import ThemeToggle from '../components/ThemeToggle.astro';
import LangSwitcher from '../components/LangSwitcher.astro';
import Footer from '../components/Footer.astro';
import { stripLocaleFromPath } from '../i18n';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  showFooter?: boolean;
  structuredData?: object;
  /**
   * When true, injects <meta name="robots" content="noindex,nofollow">.
   * Use for soft-404 utility pages (e.g. /[lang]/404/) that must return HTTP
   * 200 for client-side routing but should never be indexed.
   */
  noindex?: boolean;
}

const {
  title,
  description = 'GDKVM: Echocardiography Video Segmentation via Spatiotemporal Key-Value Memory with Gated Delta Rule',
  // Use a self-hosted, base-prefixed OG image so social crawlers don't depend
  // on third-party CDNs (cdn.jsdelivr.net refuses many crawlers due to TLS/CORS).
  // Width/height are omitted intentionally so crawlers fetch the actual file
  // rather than trusting a hardcoded 1200x630 that may not match.
  image = `${import.meta.env.BASE_URL}/gdkvm-og.png`,
  showFooter = true,
  structuredData,
  noindex = false,
} = Astro.props;

const lang = Astro.currentLocale ?? 'en';
const structuredDataJson = structuredData ? JSON.stringify(structuredData) : null;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8">
    <style is:inline>
      :root {
        --bg-color: #ffffff;
        --text-color: #374151;
      }
      html.dark {
        --bg-color: #111827;
        --text-color: #e5e7eb;
      }
      html {
        background-color: var(--bg-color);
        color: var(--text-color);
      }
      body {
        margin: 0;
        min-height: 100vh;
      }
    </style>
    <script is:inline>
      (function() {
        function applyTheme() {
          const theme = localStorage.getItem('theme')
            || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.classList.toggle('dark', theme === 'dark');
          const meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute('content', theme === 'dark' ? '#111827' : '#ffffff');
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
    <meta name="description" content={description}>
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta property="og:site_name" content="GDKVM — ICCV 2025" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:alt" content="GDKVM architecture diagram for echocardiography video segmentation" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site).href} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />

    <!-- Language alternates for SEO. With `prefixDefaultLocale: true` + [lang]/,
         build hreflang per current page so /en/reprod/ pairs with /zh/reprod/.
         Uses BASE_URL so the same code works for any subpath (avoid duplicate base in alt URLs). -->
    {(() => {
      const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
      const altPath = stripLocaleFromPath(Astro.url.pathname, baseUrl);
      return (
        <>
          <link rel="alternate" hreflang="en" href={new URL(`${baseUrl}/en${altPath}`, Astro.site).href} />
          <link rel="alternate" hreflang="zh" href={new URL(`${baseUrl}/zh${altPath}`, Astro.site).href} />
          <link rel="alternate" hreflang="x-default" href={new URL(`${baseUrl}/en${altPath}`, Astro.site).href} />
        </>
      );
    })()}

    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/favicon.png`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}/favicon.png`} />
    <link rel="manifest" href={`${import.meta.env.BASE_URL}/manifest.json`} />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111827" media="(prefers-color-scheme: dark)" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://cdn.jsdelivr.net; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';" />
    <ClientRouter fallback="none" />
    {structuredData && (
      /* TRUSTED: static JSON.stringify of academic data, served as application/ld+json. */
      <script is:inline type="application/ld+json" set:html={structuredDataJson} />
    )}
    <script>
      (function () {
        if ('serviceWorker' in navigator) {
          navigator.serviceWorker.register(`${import.meta.env.BASE_URL}/sw.js`).catch(() => {});
        }
      })();
    </script>
  </head>
  <body class="bg-white text-gray-700 dark:bg-gray-900 dark:text-gray-200 transition-colors min-h-screen flex flex-col">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-blue-600 focus:text-white focus:rounded"
    >
      Skip to main content
    </a>
    <nav aria-label="User controls" class="fixed top-4 right-4 z-50 flex items-center gap-2">
      <ThemeToggle />
      <LangSwitcher />
    </nav>
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    {showFooter && <Footer />}
    <script>
      import { initDelegatedClickHandlers } from '../scripts/dom-handlers';
      import { bindPageLifecycle } from '../scripts/page-init';
      // Re-bind on every page swap (ClientRouter) so the handlers stay
      // live after Astro's view transitions.
      bindPageLifecycle(initDelegatedClickHandlers);
    </script>
  </body>
</html>
