---
import { Icon } from 'astro-icon/components';

export interface Props {
  targetId: string;
  label?: string;
  successLabel?: string;
}

const { targetId, label = 'Copy', successLabel = 'Copied!' } = Astro.props;
---

<button
  type="button"
  data-copy-target={targetId}
  data-copy-label={label}
  data-copy-success={successLabel}
  class="copy-btn absolute top-2 right-2 z-10 bg-white dark:bg-gray-700 rounded px-2 py-1 text-xs flex items-center gap-1"
>
  <Icon name="lucide:copy" class="w-3 h-3 copy-icon" />
  <span>{label}</span>
</button>
