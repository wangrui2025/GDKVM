---
import { getRelativeLocaleUrl } from 'astro:i18n';

const currentLocale = Astro.currentLocale ?? 'en';
const targetLocale = currentLocale === 'en' ? 'zh' : 'en';
// Strip BASE_URL + leading /(en|zh) + trailing slash, default to '/'
const stripped = Astro.url.pathname
  .replace(import.meta.env.BASE_URL, '')
  .replace(/^\/(en|zh)/, '')
  .replace(/\/$/, '') || '/';
// On 404 pages (e.g. /404, /zh/404) there is no per-locale equivalent
// in dist/, so fall back to the locale root. This avoids the lang
// switch pointing at another 404.
const targetPath = /^\/?404\/?$/.test(stripped) ? '/' : stripped;
const targetUrl = getRelativeLocaleUrl(targetLocale, targetPath);
---

<a
  href={targetUrl}
  class="flex items-center gap-2 bg-gray-700 hover:bg-gray-600 text-white rounded-full px-4 py-2 text-sm font-bold transition-colors shadow-md"
  title="Switch Language"
>
  <img src={`${import.meta.env.BASE_URL}/assets/images/translate.svg`} alt="Translate" class="h-4 w-auto" loading="lazy" decoding="async" />
</a>
