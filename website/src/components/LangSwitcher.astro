---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t, stripLocaleFromPath } from '../i18n';

const currentLocale = Astro.currentLocale ?? 'en';
const targetLocale = currentLocale === 'en' ? 'zh' : 'en';
// Strip BASE_URL + optional locale prefix to get the locale-free path that
// getRelativeLocaleUrl expects. Centralized in `i18n/stripLocaleFromPath` so
// the regex isn't duplicated with Layout.astro's hreflang builder.
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = stripLocaleFromPath(Astro.url.pathname, baseUrl);
const targetUrl = getRelativeLocaleUrl(targetLocale, currentPath);
---

<a
  href={targetUrl}
  class="flex items-center gap-2 bg-gray-700 hover:bg-gray-600 text-white rounded-full px-4 py-2 text-sm font-bold transition-colors shadow-md"
  title="Switch Language"
  aria-label={currentLocale === 'zh' ? '切换语言' : 'Switch language'}
>
  <img src={`${import.meta.env.BASE_URL}/assets/images/translate.svg`} alt={t(currentLocale, 'tool.langIconAlt')} width="16" height="16" class="h-4 w-auto" loading="lazy" decoding="async" />
</a>
