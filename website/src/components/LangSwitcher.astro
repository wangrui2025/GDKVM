---
import { getRelativeLocaleUrl } from 'astro:i18n';

const currentLocale = Astro.currentLocale ?? 'en';
const targetLocale = currentLocale === 'en' ? 'zh' : 'en';
// Strip BASE_URL + optional locale prefix to get the locale-free path that
// getRelativeLocaleUrl expects. Uses RegExp (matching Layout.astro:90) so the
// pattern also works when prefixDefaultLocale routes every page under /en/ or
// /zh/ — previously a hardcoded /^\/(en|zh)/ would silently fail on root or
// subpath entries that don't carry a locale segment.
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath =
  Astro.url.pathname.replace(
    new RegExp(`^${baseUrl}/(en|zh)`),
    ''
  ).replace(/\/$/, '') || '/';
const targetUrl = getRelativeLocaleUrl(targetLocale, currentPath);
---

<a
  href={targetUrl}
  class="flex items-center gap-2 bg-gray-700 hover:bg-gray-600 text-white rounded-full px-4 py-2 text-sm font-bold transition-colors shadow-md"
  title="Switch Language"
  aria-label={currentLocale === 'zh' ? '切换语言' : 'Switch language'}
>
  <img src={`${import.meta.env.BASE_URL}/assets/images/translate.svg`} alt="Translate" width="16" height="16" class="h-4 w-auto" loading="lazy" decoding="async" />
</a>
