---
import Layout from '../layouts/Layout.astro';
import Section from './Section.astro';
import ActionButton from './ActionButton.astro';
import CopyButton from './CopyButton.astro';
import { Icon } from 'astro-icon/components';
import { getScholarlyArticleSchema } from '../utils/structuredData';
import { t } from '../i18n';
import { SITE_CONFIG, CDN_BASE } from '../config/site';
import enHome from '../content/homepage/en.json';
import zhHome from '../content/homepage/zh.json';

interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;

// Authors live in i18n content (not in the `t()` lookup because they're
// structured objects, not plain strings). Both locales must have the
// same array length and order to render the comma separators correctly.
const homeContent = (lang === 'zh' ? zhHome : enHome) as { authors: { name: string; sup: string }[] };
const authors = homeContent.authors;

/**
 * Parse "First Last" into {givenname, surname} for Highwire citation_author
 * meta tag. Handles 2-3 word English names reasonably; for institutional
 * authors that lack a clear given/surname split we emit the full name as
 * the surname field (Google Scholar accepts this for institutional entries).
 */
function splitGivenSurname(fullName: string): { givenname?: string; surname: string } {
  const parts = fullName.trim().split(/\s+/);
  if (parts.length === 1) return { surname: parts[0] };
  return {
    givenname: parts.slice(0, -1).join(' '),
    surname: parts[parts.length - 1],
  };
}

const institutionalMap: Record<string, string> = {
  'Polytechnic': 'The Hong Kong Polytechnic University',
  'Jing Qin': 'The Hong Kong Polytechnic University',
};

const citationAuthors = authors.map((a) => {
  const split = splitGivenSurname(a.name);
  return {
    ...split,
    institution: institutionalMap[a.name],
  };
});

const schema = getScholarlyArticleSchema({
  title: t(lang, 'home.publicationTitle'),
  authors: authors.map((a) => a.name),
  description: t(lang, 'home.description'),
  url: new URL(Astro.url.pathname, Astro.site).href,
  image: `${CDN_BASE}/images/publications/iccv2025-gdkvm/gdkvm.png`,
  datePublished: SITE_CONFIG.datePublished,
  venue: SITE_CONFIG.venue,
  pdfUrl: SITE_CONFIG.cvfPaperUrl,
  codeUrl: SITE_CONFIG.codeUrl,
});

/**
 * Build the Highwire/Google Scholar citation meta payload. Splits a
 * venue like "ICCV 2025" into a YYYY/MM/DD publication_date that the
 * publisher can ingest directly. Date defaults to `datePublished` if
 * no full ISO date is available in SITE_CONFIG.
 */
const citationMeta = {
  title: t(lang, 'home.publicationTitle'),
  authors: citationAuthors,
  publicationDate: `${SITE_CONFIG.datePublished.replace(/-/g, '/')}`,
  venue: SITE_CONFIG.venue,
  pdfUrl: SITE_CONFIG.cvfPaperUrl,
  abstractUrl: new URL(Astro.url.pathname, Astro.site).href,
  language: lang === 'zh' ? 'zh' : 'en',
};
---

<Layout title={t(lang, 'home.title')} description={t(lang, 'home.description')} structuredData={schema} citation={citationMeta}>
  <!-- Hero -->
  <section class="relative bg-gray-50 dark:bg-gray-800 pb-12 pt-8">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center">
        <!-- ICCV Logo -->
        <div class="mb-6">
          <img
            src={`${CDN_BASE}/images/logos/iccv.png`}
            alt="ICCV Logo"
            class="h-14 w-auto mx-auto lg:absolute lg:top-8 lg:left-8 lg:mx-0"
            loading="eager"
          />
        </div>

        <h1 class="publication-title mt-4">
          <span class="highlight-title">{t(lang, 'home.publicationTitle')}</span>
        </h1>

        <p class="text-lg mt-4 text-gray-500 dark:text-gray-400">
          {t(lang, 'home.venueFull')}
        </p>

        <div class="text-lg mt-6 font-medium">
          {
            authors.map((a, i, arr) => (
              <span class="mx-1">{a.name}<sup>{a.sup}</sup>{i < arr.length - 1 ? ',' : ''}</span>
            ))
          }
        </div>

        <div class="text-sm mt-3 text-gray-500 dark:text-gray-400">
          <div><sup>1</sup>{t(lang, 'home.affiliation1')}</div>
          <div><sup>2</sup>{t(lang, 'home.affiliation2')}</div>
          <div class="mt-2 text-xs text-gray-500 dark:text-gray-400">
            <div>{t(lang, 'home.email')}</div>
            <div>{t(lang, 'home.correspondingAuthor')}</div>
          </div>
        </div>

        <div class="flex flex-wrap justify-center gap-3 mt-8">
          <ActionButton href={SITE_CONFIG.arxivUrl} icon="academicons:arxiv" target="_blank">
            {t(lang, 'home.arxiv')}
          </ActionButton>
          <ActionButton href={SITE_CONFIG.codeUrl} icon="simple-icons:github" target="_blank">
            {t(lang, 'home.code')}
          </ActionButton>
          <ActionButton href={`${import.meta.env.BASE_URL}/${lang}/reprod/`} icon="lucide:settings">
            {t(lang, 'home.reproduction')}
          </ActionButton>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture Figure -->
  <Section>
    <div class="p-2">
      <img
        src={`${CDN_BASE}/images/publications/iccv2025-gdkvm/gdkvm.png`}
        alt="GDKVM Architecture"
        class="w-full rounded"
        loading="eager"
        decoding="async"
      />
    </div>
    <figcaption class="text-sm text-gray-600 dark:text-gray-400 text-justify mt-4 leading-relaxed">
      <strong>Figure 1.</strong> {t(lang, 'home.fig1Caption')}
    </figcaption>
  </Section>

  <!-- Abstract -->
  <Section>
    <div class="abstract-box">
      <h2 class="text-3xl font-semibold text-center mb-6 font-display">{t(lang, 'home.abstractTitle')}</h2>
      <div class="text-justify fade-in space-y-4">
        <p>{t(lang, 'home.abstractP1')}</p>
        <p>{t(lang, 'home.abstractP2')}</p>
        <p>{t(lang, 'home.abstractP3')}</p>
        <p>{t(lang, 'home.abstractP4')}</p>
      </div>
    </div>
  </Section>

  <!-- Challenges -->
  <Section>
    <h3 class="text-2xl font-semibold text-center mb-6 font-display">{t(lang, 'home.challengesTitle')}</h3>
    <div class="text-center mb-6">
      <p>{t(lang, 'home.challengesDesc')}</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3 max-w-5xl mx-auto">
      {
        [
          { src: `${CDN_BASE}/images/publications/iccv2025-gdkvm/arXiv-2512.10252v1/fig/challenge/cha_1.jpg`, alt: 'Noise', cap: '(a)' },
          { src: `${CDN_BASE}/images/publications/iccv2025-gdkvm/arXiv-2512.10252v1/fig/challenge/cha_2.jpg`, alt: 'Blur', cap: '(b)' },
          { src: `${CDN_BASE}/images/publications/iccv2025-gdkvm/arXiv-2512.10252v1/fig/challenge/cha_3.jpg`, alt: 'Shape', cap: '(c)' },
          { src: `${CDN_BASE}/images/publications/iccv2025-gdkvm/arXiv-2512.10252v1/fig/challenge/cha_4.jpg`, alt: 'Scale', cap: '(d)' },
          { src: `${CDN_BASE}/images/publications/iccv2025-gdkvm/arXiv-2512.10252v1/fig/challenge/cha_5.jpg`, alt: 'Cycle', cap: '(e)' },
          { src: `${CDN_BASE}/images/publications/iccv2025-gdkvm/arXiv-2512.10252v1/fig/challenge/cha_6.jpg`, alt: 'Dropout', cap: '(f)' },
        ].map(({ src, alt, cap }) => (
          <figure class="rounded-lg overflow-hidden bg-gray-50 dark:bg-gray-800 hover:shadow-md transition-shadow">
            <img src={src} alt={alt} loading="lazy" class="w-full h-28 object-cover" />
            <figcaption class="text-center text-xs font-medium py-1.5 text-text-secondary dark:text-text-secondary-dark">{cap} {alt}</figcaption>
          </figure>
        ))
      }
    </div>

    <div class="mt-6">
      <p class="text-sm text-gray-600 dark:text-gray-400 text-justify">
        <strong>Figure 2.</strong> {t(lang, 'home.fig2Caption')}
      </p>
    </div>
  </Section>

  <!-- BibTeX -->
  <Section id="BibTeX">
    <h2 class="text-3xl font-semibold text-center mb-6 font-display">{t(lang, 'home.bibtexTitle')}</h2>
    <div class="relative">
      <CopyButton targetId="bibtex-content" label={t(lang, 'home.copy')} successLabel={t(lang, 'home.copied')} />
      <pre
        class="bg-gray-100 dark:bg-gray-800 rounded-lg p-6 text-sm overflow-x-auto"
        is:raw
      ><code id="bibtex-content">@InProceedings&#123;Wang_ICCV25_GDKVM,
    author    = &#123;Wang, Rui and Sun, Yimu and Guo, Jingxing and Wu, Huisi and Qin, Jing&#125;,
    title     = &#123;&#123;GDKVM&#125;: Echocardiography Video Segmentation via Spatiotemporal Key-Value Memory with Gated Delta Rule&#125;,
    booktitle = &#123;Proceedings of the IEEE/CVF International Conference on Computer Vision (ICCV)&#125;,
    month     = &#123;October&#125;,
    year      = &#123;2025&#125;,
    pages     = &#123;12191-12200&#125;
&#125;</code></pre>
    </div>
  </Section>

  <!-- Additional Resources -->
  <Section class="pb-8">
    <div class="text-center">
      <h2 class="text-3xl font-semibold text-center mb-6 font-display">{t(lang, 'home.resourcesTitle')}</h2>
      <div class="flex flex-wrap justify-center gap-3">
        <ActionButton
          href={SITE_CONFIG.cvfPaperUrl}
          icon="lucide:file-text"
          target="_blank"
        >
          {t(lang, 'home.cvfPaper')}
        </ActionButton>
        <ActionButton
          href={SITE_CONFIG.posterUrl}
          icon="lucide:image"
          target="_blank"
        >
          {t(lang, 'home.poster')}
        </ActionButton>
      </div>
    </div>
  </Section>

  <!-- To-Do List -->
  <Section compact>
    <div class="text-center">
      <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-gray-400">{t(lang, 'home.todoTitle')}</p>
      <ul class="list-none text-sm text-gray-400 opacity-70">
        <li class="mb-1"><Icon name="lucide:square" class="w-3 h-3 inline mr-1" /> {t(lang, 'home.todo1')}</li>
        <li><Icon name="lucide:square" class="w-3 h-3 inline mr-1" /> {t(lang, 'home.todo2')}</li>
      </ul>
    </div>
  </Section>

  <script>
    // KaTeX auto-render is bundled via Astro's module graph (katex ^0.17.0 is
    // already a project dependency), eliminating the 39KB CDN script. The
    // side-effect import registers `renderMathInElement` on globalThis,
    // which the katex.ts init helper then calls.
    import 'katex/dist/contrib/auto-render.min.js';
    import { initKatex } from '../scripts/katex';
    import { bindPageLifecycle } from '../scripts/page-init';
    bindPageLifecycle(initKatex);
  </script>
</Layout>
