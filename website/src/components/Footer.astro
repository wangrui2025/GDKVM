---
import { t } from '../i18n';
const lang = Astro.currentLocale ?? 'en';
---

<footer class="py-8 bg-gray-50 dark:bg-gray-800 mt-8">
  <div class="max-w-5xl mx-auto px-4 text-center">
    <p class="text-sm text-gray-500 dark:text-gray-400">
      {t(lang, 'footer.templateFrom')} <a href="https://github.com/nerfies/nerfies.github.io" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline">Nerfies</a>. {t(lang, 'footer.licensedUnder')} <a rel="license" href="http://creativecommons.org/licenses/by-sa/4.0/" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline">CC BY-SA 4.0</a>.
    </p>
  </div>
</footer>
