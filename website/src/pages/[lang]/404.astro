---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t } from '../../i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
  ];
}

// Lang param comes from the dynamic [lang] route — guarantees each
// locale has its own 404 page (no more broken lang switch from
// /404 → /zh/404/ which doesn't exist).
const { lang } = Astro.params as { lang: 'en' | 'zh' };

const title = t(lang, '404.title');
const message = t(lang, '404.message');
const homeLabel = t(lang, '404.homeLabel');
---

<Layout title={title}>
  <Section class="text-center">
    <h1 class="text-6xl font-bold font-display mb-4">404</h1>
    <p class="text-xl mb-8">{message}</p>
    <a
      href={getRelativeLocaleUrl(lang, '/')}
      class="inline-block px-6 py-3 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors"
    >
      {homeLabel}
    </a>
  </Section>
</Layout>
