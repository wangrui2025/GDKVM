---
import HomePage from '../../components/HomePage.astro';
import { isLocale, type Locale, getStaticPaths } from '../../i18n';

export { getStaticPaths };

// Narrow dynamic route param to Locale via shared type guard.
const lang: Locale = isLocale(Astro.params.lang) ? Astro.params.lang : 'en';
---

<HomePage lang={lang} />
