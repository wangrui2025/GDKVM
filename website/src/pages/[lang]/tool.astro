---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';
import { t } from '../../i18n';
import '../../styles/toolstyle.css';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const lang = Astro.params.lang as 'en' | 'zh';
---

<Layout title={t(lang, 'tool.title')} description={t(lang, 'tool.description')} showFooter={false} image={'https://cdn.jsdelivr.net/gh/mykcs/academic@v1.1.0/images/publications/iccv2025-gdkvm/gdkvm.png'}>
  <Section>
    <h1 class="text-4xl font-bold font-[Google_Sans] mb-4">
      {t(lang, 'tool.title')}
    </h1>
    <form id="modelForm">
      <div class="select-item">
        <label for="modelSize">{t(lang, 'tool.modelSize')}</label>
        <input type="text" id="modelSize" placeholder="e.g.1000000 or 1e6" required>
      </div>
      <div class="select-item">
        <label for="trainingTokens">{t(lang, 'tool.trainingTokens')}</label>
        <input type="text" id="trainingTokens" placeholder="e.g.5000000 or 5e6" required>
      </div>
      <button type="submit">{t(lang, 'tool.calculate')}</button>
    </form>

    <div id="result">
      <h3>{t(lang, 'tool.results')}</h3>
      <p id="bsValue">{t(lang, 'tool.optimalBs')}</p>
      <p id="lrValue">{t(lang, 'tool.lr')}</p>
    </div>
  </Section>

  <script>
    import { initToolPage } from '../../scripts/tool';
    document.addEventListener('astro:page-load', initToolPage);
    if (document.readyState !== 'loading') {
      initToolPage();
    } else {
      document.addEventListener('DOMContentLoaded', initToolPage);
    }
  </script>
</Layout>
