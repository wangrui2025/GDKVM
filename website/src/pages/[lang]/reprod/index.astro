---
import Layout from '../../../layouts/Layout.astro';
import Section from '../../../components/Section.astro';
import ActionButton from '../../../components/ActionButton.astro';
import CopyButton from '../../../components/CopyButton.astro';
import { Icon } from 'astro-icon/components';
import { t } from '../../../i18n';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const { lang } = Astro.params;
const homeUrl = { en: `${import.meta.env.BASE_URL}/`, zh: `${import.meta.env.BASE_URL}/${lang}/` }[lang] ?? `${import.meta.env.BASE_URL}/`;
---

<Layout title={t(lang, 'reprod.title')} description={t(lang, 'reprod.description')} showFooter={false}>
  <!-- Hero -->
  <section class="bg-gray-100 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 mb-8">
    <div class="max-w-5xl mx-auto px-4 py-12 text-center">
      <h1 class="text-4xl font-bold font-[Google_Sans] mb-4">
        {t(lang, 'reprod.pageTitle')}
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-300 mt-2">
        {t(lang, 'reprod.subtitle')}
      </p>
      <div class="mt-6">
        <ActionButton href={homeUrl} icon="fas fa-arrow-left">
          {t(lang, 'reprod.backHome')}
        </ActionButton>
      </div>
    </div>
  </section>

  <Section class="pb-12">
    <div class="fade-in">
      <!-- 1. Environment Setup -->
      <h2 class="text-2xl font-semibold mt-10 mb-6 pb-2 border-b-2 border-gray-100 dark:border-gray-700 font-[Google_Sans]" id="environment">
        {t(lang, 'reprod.envTitle')}
      </h2>

      <h3 class="text-xl font-semibold mt-8 mb-4 text-gray-700 dark:text-gray-300">
        {t(lang, 'reprod.cleanTitle')}
      </h3>
      <p class="mb-4">{t(lang, 'reprod.cleanP1')}</p>

      <p class="mb-2">{t(lang, 'reprod.cleanConda')}</p>
      <div class="relative mb-4">
        <CopyButton targetId="code-01" />
        <pre id="code-01" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">conda deactivate</code></pre>
      </div>

      <p class="mb-2">{t(lang, 'reprod.cleanVenv')}</p>
      <div class="relative mb-4">
        <CopyButton targetId="code-02" />
        <pre id="code-02" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">deactivate</code></pre>
      </div>

      <p class="text-xs text-gray-500 dark:text-gray-400 mt-2 mb-6">{t(lang, 'reprod.cleanNote')}</p>

      <h3 class="text-xl font-semibold mt-8 mb-4 text-gray-700 dark:text-gray-300">
        {t(lang, 'reprod.installUvTitle')}
      </h3>
      <p class="mb-4">{t(lang, 'reprod.installUvDesc')}</p>

      <p class="mb-2">{t(lang, 'reprod.installUvNoNet')}</p>
      <div class="relative mb-4">
        <CopyButton targetId="code-03" />
        <pre id="code-03" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">pip install uv</code></pre>
      </div>

      <p class="mb-2">{t(lang, 'reprod.installUvUpgrade')}</p>
      <div class="relative mb-4">
        <CopyButton targetId="code-04" />
        <pre id="code-04" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">pip install --upgrade uv</code></pre>
      </div>

      <p class="mb-2">{t(lang, 'reprod.installUvVerify')}</p>
      <div class="relative mb-4">
        <CopyButton targetId="code-05" />
        <pre id="code-05" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">uv -V</code></pre>
      </div>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-6">{t(lang, 'reprod.installUvBaseline')}</p>

      <h3 class="text-xl font-semibold mt-8 mb-4 text-gray-700 dark:text-gray-300">
        {t(lang, 'reprod.getCodeTitle')}
      </h3>
      <p class="mb-4">{t(lang, 'reprod.getCodeDesc')}</p>
      <div class="relative mb-4">
        <CopyButton targetId="code-06" />
        <pre id="code-06" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">git clone https://github.com/wangrui2025/GDKVM.git gdkvm_20251215</code></pre>
      </div>

      <p class="mb-2">{t(lang, 'reprod.getCodeEnter')}</p>
      <div class="relative mb-4">
        <CopyButton targetId="code-07" />
        <pre id="code-07" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">cd gdkvm_20251215</code></pre>
      </div>

      <p class="mb-2">{t(lang, 'reprod.getCodeStructure')}</p>
      <div class="relative mb-6">
        <pre class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">.
├── .python-version    # {t(lang, 'reprod.fileStruct.pythonVersion')}
├── pyproject.toml     # {t(lang, 'reprod.fileStruct.projectConfig')}
├── uv.lock            # {t(lang, 'reprod.fileStruct.lockFile')}
└── ...                # {t(lang, 'reprod.fileStruct.otherFiles')}</code></pre>
      </div>

      <h3 class="text-xl font-semibold mt-8 mb-4 text-gray-700 dark:text-gray-300">
        {t(lang, 'reprod.initTitle')}
      </h3>
      <p class="mb-4">{t(lang, 'reprod.initDesc')}</p>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-4">{t(lang, 'reprod.initNote')}</p>

      <div class="relative mb-4">
        <CopyButton targetId="code-08" />
        <pre id="code-08" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">uv sync</code></pre>
      </div>

      <!-- Troubleshooting box -->
      <div class="advanced-box">
        <div class="font-bold text-yellow-800 dark:text-yellow-200 mb-3 flex items-center">
          <Icon name="lucide:wrench" class="mr-2" />
          {t(lang, 'reprod.troubleshootingTitle')}
        </div>
        <p class="mb-4 text-sm">
          <strong>{t(lang, 'reprod.troubleshooting.scenario')}</strong> {t(lang, 'reprod.troubleshooting.scenarioUvSync')}
        </p>
        <p class="mb-4 text-sm">
          <strong>{t(lang, 'reprod.troubleshooting.solution')}</strong> {t(lang, 'reprod.troubleshooting.solutionMirror')}
        </p>
        <p class="mb-2 text-sm">{t(lang, 'reprod.troubleshooting.checkVersions')}</p>
        <div class="relative mb-4">
        <CopyButton targetId="code-09" />
        <pre id="code-09" class="bg-white/50 dark:bg-gray-800/50 rounded p-3 text-sm"><code class="language-bash">uv python list</code></pre>
        </div>
        <p class="mb-2 text-sm">{t(lang, 'reprod.troubleshooting.installMirror')}</p>
        <div class="relative mb-4">
        <CopyButton targetId="code-10" />
        <pre id="code-10" class="bg-white/50 dark:bg-gray-800/50 rounded p-3 text-sm"><code class="language-bash">uv python install 3.12.12 --mirror https://github-proxy.lixxing.top/https://github.com/astral-sh/python-build-standalone/releases/download</code></pre>
        </div>
        <p class="text-sm">{t(lang, 'reprod.troubleshootingAfterInstall')}</p>
      </div>

      <!-- Compatibility details -->
      <details class="compatibility-box">
        <summary class="compatibility-header">
          <span><Icon name="lucide:triangle-alert" class="mr-2" /> {t(lang, 'reprod.versionConstraints')}</span>
          <span class="icon"><Icon name="lucide:chevron-down" /></span>
        </summary>
        <div class="compatibility-content">
          <ol class="list-decimal pl-5 space-y-4 text-sm">
            <li>
              <strong>Pydantic {t(lang, 'reprod.versionConstraints.pydanticConflict')} &lt;2.12</strong>
              <div class="mt-1 pl-1 text-xs">
                <p class="mb-1"><strong><Icon name="lucide:bug" class="text-red-500 w-4" /> {t(lang, 'reprod.versionConstraints.pydanticIssue')}</strong> {t(lang, 'reprod.versionConstraints.pydanticIssueDesc')}</p>
                <p><strong><Icon name="lucide:circle-check" class="text-green-500 w-4" /> {t(lang, 'reprod.versionConstraints.pydanticFix')}</strong> {t(lang, 'reprod.versionConstraints.pydanticFixDesc')}</p>
              </div>
            </li>
            <li>
              <strong>Wandb {t(lang, 'reprod.versionConstraints.wandbCompat')}</strong>
              <div class="mt-1 pl-1 text-xs">
                <p class="mb-1"><strong><Icon name="lucide:bug" class="text-red-500 w-4" /> {t(lang, 'reprod.versionConstraints.wandbIssue')}</strong> {t(lang, 'reprod.versionConstraints.wandbIssueDesc')}</p>
                <p><strong><Icon name="lucide:circle-check" class="text-green-500 w-4" /> {t(lang, 'reprod.versionConstraints.wandbFix')}</strong> {t(lang, 'reprod.versionConstraints.wandbFixDesc')}</p>
              </div>
            </li>
            <li>
              <strong>SSL/TLS {t(lang, 'reprod.versionConstraints.sslCert')}</strong>
              <div class="mt-1 pl-1 text-xs">
                <p class="mb-1"><strong><Icon name="lucide:bug" class="text-red-500 w-4" /> {t(lang, 'reprod.versionConstraints.sslIssue')}</strong> {t(lang, 'reprod.versionConstraints.sslIssueDesc')}</p>
                <p class="mb-2"><strong><Icon name="lucide:circle-check" class="text-green-500 w-4" /> {t(lang, 'reprod.versionConstraints.sslFix')}</strong> {t(lang, 'reprod.versionConstraints.sslFixDesc')}</p>
                <div class="mb-2">
                  <span class="inline-block bg-yellow-100 dark:bg-yellow-900 text-yellow-800 dark:text-yellow-200 text-xs px-2 py-0.5 rounded mb-1">{t(lang, 'reprod.versionConstraints.sslOptA')}</span>
                  <div class="relative">
        <CopyButton targetId="code-11" />
        <pre id="code-11" class="bg-white/50 dark:bg-gray-800/50 rounded p-2 text-sm"><code class="language-bash">uv add wandb --native-tls</code></pre>
                  </div>
                </div>
                <div>
                  <span class="inline-block bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 text-xs px-2 py-0.5 rounded mb-1">{t(lang, 'reprod.versionConstraints.sslOptB')}</span>
                  <div class="relative">
        <CopyButton targetId="code-12" />
        <pre id="code-12" class="bg-white/50 dark:bg-gray-800/50 rounded p-2 text-sm"><code class="language-bash">export UV_NATIVE_TLS=1</code></pre>
                  </div>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">* {t(lang, 'reprod.versionConstraints.sslOptBDesc')}</p>
                </div>
              </div>
            </li>
          </ol>
        </div>
      </details>

      <h3 class="text-xl font-semibold mt-8 mb-4 text-gray-700 dark:text-gray-300">
        {t(lang, 'reprod.activateTitle')}
      </h3>
      <div class="relative mb-4">
        <CopyButton targetId="code-13" />
        <pre id="code-13" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">source .venv/bin/activate</code></pre>
      </div>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-4">{t(lang, 'reprod.activateNote')}</p>
      <p class="mb-2">{t(lang, 'reprod.activateVerify')}</p>
      <div class="relative mb-4">
        <CopyButton targetId="code-14" />
        <pre id="code-14" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">which python</code></pre>
      </div>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-6">{t(lang, 'reprod.activateExample')}<br><code>/data/Anon/Repo/gdkvm_20251215/.venv/bin/python</code></p>

      <!-- 2. Data Preparation -->
      <h2 class="text-2xl font-semibold mt-10 mb-6 pb-2 border-b-2 border-gray-100 dark:border-gray-700 font-[Google_Sans]" id="data">
        {t(lang, 'reprod.dataTitle')}
      </h2>
      <p class="mb-4">{t(lang, 'reprod.dataDesc')}</p>

      <h3 class="text-xl font-semibold mt-6 mb-4 text-gray-700 dark:text-gray-300">{t(lang, 'reprod.datasetDownload')}</h3>
      <div class="compact-card">
        <div class="mb-3 flex flex-wrap items-center gap-x-4 gap-y-2">
          <span class="font-bold text-blue-700 dark:text-blue-400"><Icon name="lucide:database" class="mr-1" /> {t(lang, 'reprod.processedData')}:</span>
          <span class="whitespace-nowrap"><strong>CAMUS</strong> <a href="https://huggingface.co/datasets/miyuki17/camus_png256x256_10f_20250709" target="_blank" class="link-tag">HuggingFace <Icon name="lucide:external-link" /></a></span>
          <span class="whitespace-nowrap"><strong>EchoNet-Dynamic</strong> <a href="https://huggingface.co/datasets/miyuki17/EchoNet-Dynamic" target="_blank" class="link-tag">HuggingFace <Icon name="lucide:external-link" /></a></span>
        </div>
        <div class="pt-3 border-t border-dashed border-gray-200 dark:border-gray-600 text-xs text-gray-500 flex flex-wrap items-center gap-x-4 gap-y-2">
          <span class="font-bold"><Icon name="lucide:archive" class="mr-1" /> {t(lang, 'reprod.rawData')}:</span>
          <span class="whitespace-nowrap"><strong>CAMUS</strong> <a href="https://www.creatis.insa-lyon.fr/Challenge/camus/" target="_blank" class="link-subtle">{t(lang, 'reprod.dataset.official')}</a> <a href="https://huggingface.co/datasets/miyuki17/CAMUS_public" target="_blank" class="link-subtle">HuggingFace {t(lang, 'reprod.dataset.mirror')}</a></span>
          <span class="whitespace-nowrap"><strong>EchoNet-Dynamic</strong> <a href="https://echonet.github.io/dynamic/" target="_blank" class="link-subtle">{t(lang, 'reprod.dataset.official')}</a> <a href="https://huggingface.co/datasets/miyuki17/EchoNet-Dynamic-zip" target="_blank" class="link-subtle">{t(lang, 'reprod.dataset.mirror')}</a></span>
        </div>
      </div>

      <!-- 3. Training & Evaluation -->
      <h2 class="text-2xl font-semibold mt-10 mb-6 pb-2 border-b-2 border-gray-100 dark:border-gray-700 font-[Google_Sans]" id="training">
        {t(lang, 'reprod.trainingTitle')}
      </h2>

      <h3 class="text-xl font-semibold mt-6 mb-4 text-gray-700 dark:text-gray-300">{t(lang, 'reprod.trainingModelTitle')}</h3>

      <p class="mb-2 font-semibold">{t(lang, 'reprod.trainingConfig')}</p>
      <p class="mb-4">{t(lang, 'reprod.trainingConfigDesc')}</p>
      <div class="relative mb-6">
        <CopyButton targetId="code-15" />
        <pre id="code-15" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">CUDA_VISIBLE_DEVICES: 0,1 # {t(lang, 'reprod.training.gpuDevice')}
MASTER_PORT: 29500        # {t(lang, 'reprod.training.masterPort')}</code></pre>
      </div>

      <p class="mb-2 font-semibold">{t(lang, 'reprod.trainingHyper')}</p>
      <p class="mb-4">{t(lang, 'reprod.trainingHyperDesc')}</p>
      <div class="relative mb-6">
        <CopyButton targetId="code-16" />
        <pre id="code-16" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-yaml">data_path: /data/Anon/dataset/camus_png256x256_10f_20250709/   # {t(lang, 'reprod.training.datasetPath')}
batch_size: 8                                                  # {t(lang, 'reprod.training.batchSize')}
learning_rate: 1.0e-4                                          # {t(lang, 'reprod.training.learningRate')}
num_iterations: 3000                                           # {t(lang, 'reprod.training.totalIter')}
eval_stage:
  num_vis: 0                                                   # {t(lang, 'reprod.training.visCount')}
  wandb_mode: "offline"                                        # {t(lang, 'reprod.training.wandbMode')}</code></pre>
      </div>

      <p class="mb-2 font-semibold">{t(lang, 'reprod.trainingExec')}</p>
      <p class="mb-2">{t(lang, 'reprod.trainingExecPerm')}</p>
      <div class="relative mb-4">
        <CopyButton targetId="code-17" />
        <pre id="code-17" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">chmod +x ./train.sh</code></pre>
      </div>
      <p class="mb-2">{t(lang, 'reprod.trainingExecStart')}</p>
      <div class="relative mb-6">
        <CopyButton targetId="code-18" />
        <pre id="code-18" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">./train.sh</code></pre>
      </div>

      <h3 class="text-xl font-semibold mt-6 mb-4 text-gray-700 dark:text-gray-300">{t(lang, 'reprod.outputsTitle')}</h3>
      <p class="mb-4">{t(lang, 'reprod.outputsDesc')}</p>
      <pre class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm mb-6"><code>gdkvm_20251215/outputs</code></pre>

      <h3 class="text-xl font-semibold mt-6 mb-4 text-gray-700 dark:text-gray-300">{t(lang, 'reprod.wandbTitle')}</h3>
      <p class="mb-4">{t(lang, 'reprod.wandbDesc')}</p>
      <ul class="list-disc pl-5 mb-4 space-y-1">
        <li><strong>{t(lang, 'reprod.wandbLogPath')}</strong> <code>gdkvm_20251215/wandb</code></li>
        <li><strong>{t(lang, 'reprod.wandbRunDir')}</strong> {t(lang, 'reprod.wandb.runDirDesc')}</li>
      </ul>
      <p class="mb-2 font-semibold">{t(lang, 'reprod.wandbUpload')}</p>
      <p class="mb-4">{t(lang, 'reprod.wandbUploadDesc')}</p>
      <div class="relative mb-6">
        <CopyButton targetId="code-19" />
        <pre id="code-19" class="bg-gray-100 dark:bg-gray-800 rounded p-4 text-sm"><code class="language-bash">wandb sync gdkvm_20251215/wandb/offline-run-20251215_123456-abcdef1gh</code></pre>
      </div>
    </div>
  </Section>

  <footer class="py-8 bg-gray-50 dark:bg-gray-800 mt-8">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <p class="text-xs text-gray-500 dark:text-gray-400">{t(lang, 'reprod.footerNote')}</p>
    </div>
  </footer>

</Layout>
