---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="GDKVM | Reproduction" description="GDKVM Reproduction Process">
  <section class="hero is-light">
    <div class="hero-body">
      <div class="container is-max-desktop">
        <div class="columns is-centered">
          <div class="column has-text-centered">
            <h1 class="title is-1 publication-title">
              <span lang="en">Reproduction Process</span><span lang="zh">Reproduction Process</span>
            </h1>
            <div style="margin-top: 1.5rem;">
              <a href="/" class="button is-dark is-rounded">
                <span class="icon"><i class="fas fa-arrow-left"></i></span>
                <span lang="en">Back to Home</span><span lang="zh">Back to Home</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container is-max-desktop content fade-in">
      <h2 class="section-title">
        <span lang="en">Environment Setup</span><span lang="zh">Environment Setup</span>
      </h2>

      <div class="code-container">
        <button class="button is-small is-light copy-btn" data-copy="git clone https://github.com/wangrui2025/GDKVM.git gdkvm_20251215">
          <span class="icon"><i class="fas fa-copy"></i></span><span>Copy</span>
        </button>
        <pre><code>git clone https://github.com/wangrui2025/GDKVM.git gdkvm_20251215</code></pre>
      </div>

      <div class="code-container">
        <button class="button is-small is-light copy-btn" data-copy="cd gdkvm_20251215 && uv sync">
          <span class="icon"><i class="fas fa-copy"></i></span><span>Copy</span>
        </button>
        <pre><code>cd gdkvm_20251215 && uv sync</code></pre>
      </div>

      <div class="code-container">
        <button class="button is-small is-light copy-btn" data-copy="source .venv/bin/activate">
          <span class="icon"><i class="fas fa-copy"></i></span><span>Copy</span>
        </button>
        <pre><code>source .venv/bin/activate</code></pre>
      </div>

      <div class="code-container">
        <button class="button is-small is-light copy-btn" data-copy="chmod +x ./train.sh && ./train.sh">
          <span class="icon"><i class="fas fa-copy"></i></span><span>Copy</span>
        </button>
        <pre><code>chmod +x ./train.sh && ./train.sh</code></pre>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <div class="content has-text-centered">
        <p class="is-size-7 has-text-grey">
          <span lang="en">All references to "today" refer to December 15, 2025.</span>
          <span lang="zh">All references to "today" refer to December 15, 2025.</span>
        </p>
      </div>
    </div>
  </footer>

  <button id="lang-toggle" class="lang-btn" title="Switch Language">
    <img src="assets/images/translate.svg" alt="Translate" style="height: 1.2rem; width: auto;" />
  </button>

  <style is:global>
    .section-title { font-size: 1.5rem !important; margin-top: 2.5rem; margin-bottom: 1.5rem; font-weight: 600; color: #363636; border-bottom: 2px solid #f5f5f5; padding-bottom: 0.5rem; }
    .code-container { position: relative; margin-bottom: 1rem; }
    pre { background-color: #f5f5f5; padding: 1rem; border-radius: 4px; overflow-x: auto; }
    .copy-btn { position: absolute; top: 0.5rem; right: 0.5rem; opacity: 0.7; transition: opacity 0.2s; border: 1px solid #dbdbdb; cursor: pointer; z-index: 10; }
    .copy-btn:hover { opacity: 1; }
    .hero { background-color: #f8f9fa; margin-bottom: 2rem; border-bottom: 1px solid #eaeaea; }
  </style>

  <script>
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy');
        if (!text) return;
        navigator.clipboard.writeText(text).then(() => {
          const icon = btn.querySelector('.icon i');
          const textSpan = btn.querySelector('span:last-child');
          const originalText = textSpan.innerText;
          icon.className = 'fas fa-check';
          textSpan.innerText = 'Copied!';
          btn.classList.add('is-success');
          setTimeout(() => {
            icon.className = 'fas fa-copy';
            textSpan.innerText = originalText;
            btn.classList.remove('is-success');
          }, 2000);
        });
      });
    });

    const langBtn = document.getElementById('lang-toggle');
    const htmlTag = document.documentElement;
    if (langBtn) {
      langBtn.addEventListener('click', () => {
        const contentContainer = document.querySelector('.content');
        contentContainer?.classList.remove('fade-in');
        void contentContainer?.offsetWidth;
        if (htmlTag.classList.contains('lang-en')) {
          htmlTag.classList.replace('lang-en', 'lang-zh');
          try { localStorage.setItem('lang', 'zh'); } catch(e) {}
        } else {
          htmlTag.classList.replace('lang-zh', 'lang-en');
          try { localStorage.setItem('lang', 'en'); } catch(e) {}
        }
        contentContainer?.classList.add('fade-in');
      });
    }
  </script>
</BaseLayout>
