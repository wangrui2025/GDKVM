---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';

const lang = Astro.currentLocale ?? 'en';
const isZh = lang === 'zh';

const title = isZh ? '页面未找到' : 'Page Not Found';
const message = isZh
  ? '抱歉，您访问的页面不存在。'
  : "Sorry, the page you're looking for doesn't exist.";
const homeLabel = isZh ? '返回首页' : 'Back to Home';
---

<Layout title={title}>
  <Section class="text-center">
    <h1 class="text-6xl font-bold mb-4">404</h1>
    <p class="text-xl mb-8">{message}</p>
    <a
      href={import.meta.env.BASE_URL}
      class="inline-block px-6 py-3 rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition-colors"
    >
      {homeLabel}
    </a>
  </Section>
</Layout>
